# Reverse proxy for the WhatsApp Gateway on developer-01.
# Mirrors the appointment-developers pattern. Copy to
# /etc/nginx/sites-available/wa-gateway, symlink into sites-enabled, then run
# `certbot --nginx -d dev01-gateway.doctorapiesitos.com` to add the SSL block.

server {
    server_name dev01-gateway.doctorapiesitos.com;

    proxy_read_timeout 720s;
    proxy_connect_timeout 720s;
    proxy_send_timeout 720s;
    client_max_body_size 100M;

    # Reserved for future gateway WebSocket traffic (admin console / live status).
    location /ws {
        proxy_pass http://127.0.0.1:3010;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }

    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }
}

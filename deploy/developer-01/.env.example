# developer-01 gateway environment.
# Copy to `.env` on the server and fill the secrets there. Never commit `.env`.

NODE_ENV=production
PORT=3010
LOG_LEVEL=info

# Baileys session storage (mounted volume).
SESSION_ROOT=/app/sessions

# Downloaded media attachments (kept on the same mounted volume as sessions).
MEDIA_ROOT=/app/sessions/media

# Postgres (the db service in this compose stack).
POSTGRES_PASSWORD=
DATABASE_URL=postgres://gateway:CHANGE_ME@db:5432/gateway

# Max outbound text length (also editable at runtime on the Parameters screen).
MAX_TEXT_LENGTH=4096

# Console authentication (single admin). The admin is created on first boot from
# these values; change the password afterwards on the Security screen.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret used to sign console session tokens (generate: openssl rand -hex 32).
# Must stay stable across restarts or sessions are invalidated.
AUTH_SECRET=
# Session lifetime in hours (default 168 = 7 days).
AUTH_TOKEN_TTL_HOURS=168

# Initial value for the programmatic API key n8n sends as `X-Gateway-Api-Key`
# (generate: openssl rand -hex 32). Can be rotated on the Security screen.
GATEWAY_API_KEY=

# Secret used to HMAC-sign outbound webhooks (generate: openssl rand -hex 32).
WEBHOOK_SECRET=

# Base URL of developer-01's n8n webhook endpoints.
N8N_WEBHOOK_BASE_URL=https://n8n-developer-01.doctorapiesitos.com/webhook

# developer-01 gateway environment.
# Copy to `.env` on the server and fill the secrets there. Never commit `.env`.

NODE_ENV=production
PORT=3010
LOG_LEVEL=info

# Baileys session storage (mounted volume).
SESSION_ROOT=/app/sessions

# Shared secret n8n must send as `X-Gateway-Api-Key` (generate: openssl rand -hex 32).
GATEWAY_API_KEY=

# Secret used to HMAC-sign outbound webhooks (generate: openssl rand -hex 32).
WEBHOOK_SECRET=

# Base URL of developer-01's n8n webhook endpoints.
N8N_WEBHOOK_BASE_URL=https://n8n-developer-01.doctorapiesitos.com/webhook
